---
---

<section id="skills" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-center text-slate-900 mb-3">Built for AI Agents</h2>
    <p class="text-center text-slate-500 mb-14 max-w-xl mx-auto">AgentWallet is an OpenClaw Skill. Any AI agent can install it and manage crypto wallets through a standard protocol.</p>

    <!-- Agent workflow -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white rounded-xl p-6 border border-slate-100 text-center">
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">User Request</h3>
        <p class="text-sm text-slate-500">"Send 0.1 ETH to Alice"</p>
        <p class="text-xs text-slate-400 mt-2">via Telegram, Slack, or any chat</p>
      </div>

      <div class="bg-white rounded-xl p-6 border border-slate-100 text-center relative">
        <div class="hidden md:block absolute -left-3 top-1/2 -translate-y-1/2 text-slate-300">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" /></svg>
        </div>
        <div class="w-12 h-12 rounded-xl bg-emerald-50 flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-600">
            <path d="M12 2a4 4 0 014 4v1a2 2 0 012 2v7a4 4 0 01-4 4H10a4 4 0 01-4-4V9a2 2 0 012-2V6a4 4 0 014-4z" />
            <circle cx="12" cy="13" r="1" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">AI Agent</h3>
        <p class="text-sm text-slate-500">Invokes <code class="text-xs bg-slate-100 px-1.5 py-0.5 rounded font-mono">agentwallet</code> skill</p>
        <p class="text-xs text-slate-400 mt-2">via OpenClaw protocol</p>
      </div>

      <div class="bg-white rounded-xl p-6 border border-slate-100 text-center relative">
        <div class="hidden md:block absolute -left-3 top-1/2 -translate-y-1/2 text-slate-300">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14m-7-7l7 7-7 7" /></svg>
        </div>
        <div class="w-12 h-12 rounded-xl bg-slate-100 flex items-center justify-center mx-auto mb-4">
          <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600">
            <path d="M21 12V7H5a2 2 0 010-4h14v4" />
            <path d="M3 5v14a2 2 0 002 2h16v-5" />
            <path d="M18 12a2 2 0 000 4h4v-4h-4z" />
          </svg>
        </div>
        <h3 class="font-semibold text-slate-900 mb-2">Wallet Action</h3>
        <p class="text-sm text-slate-500">Signs & broadcasts transaction</p>
        <p class="text-xs text-slate-400 mt-2">keys never leave the vault</p>
      </div>
    </div>

    <!-- Install command -->
    <div class="max-w-2xl mx-auto">
      <div class="bg-slate-950 rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10">
        <div class="flex items-center gap-2 px-4 py-3 bg-slate-900/50 border-b border-slate-800">
          <div class="w-3 h-3 rounded-full bg-slate-700"></div>
          <div class="w-3 h-3 rounded-full bg-slate-700"></div>
          <div class="w-3 h-3 rounded-full bg-slate-700"></div>
          <span class="ml-2 text-xs text-slate-500 font-mono">install</span>
        </div>
        <div class="p-6 font-mono text-sm">
          <div class="flex items-center gap-2 text-slate-400">
            <span class="text-emerald-400">$</span>
            <span class="text-white">npx @anthropic-ai/claw install @phlegonlabs/agentwallet</span>
          </div>
          <div class="mt-3 text-slate-500 pl-4">
            <p class="text-emerald-400">&#10003; Skill installed: @phlegonlabs/agentwallet</p>
            <p class="mt-1">Agent can now manage wallets across 12 chains.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
