  {
    name: "Solana",
    icon: '<path d="M5.5 16.5c.1-.1.2-.2.4-.2h13.8c.3 0 .4.3.2.5l-2.8 2.8c-.1.1-.2.2-.4.2H2.9c-.3 0-.4-.3-.2-.5l2.8-2.8z" fill="url(#sol-a)"/><path d="M5.5 4.4c.1-.1.3-.2.4-.2h13.8c.3 0 .4.3.2.5L17.1 7.5c-.1.1-.2.2-.4.2H2.9c-.3 0-.4-.3-.2-.5l2.8-2.8z" fill="url(#sol-b)"/><path d="M18.5 10.4c-.1-.1-.2-.2-.4-.2H4.3c-.3 0-.4.3-.2.5l2.8 2.8c.1.1.2.2.4.2h13.8c.3 0 .4-.3.2-.5l-2.8-2.8z" fill="url(#sol-c)"/><defs><linearGradient id="sol-a" x1="19" y1="3" x2="5" y2="21" gradientUnits="userSpaceOnUse"><stop stop-color="#00FFA3"/><stop offset="1" stop-color="#DC1FFF"/></linearGradient><linearGradient id="sol-b" x1="14" y1="1" x2="2" y2="16" gradientUnits="userSpaceOnUse"><stop stop-color="#00FFA3"/><stop offset="1" stop-color="#DC1FFF"/></linearGradient><linearGradient id="sol-c" x1="17" y1="2" x2="3" y2="19" gradientUnits="userSpaceOnUse"><stop stop-color="#00FFA3"/><stop offset="1" stop-color="#DC1FFF"/></linearGradient></defs>',
  },
];
---

<section class="py-16 px-6 border-t border-slate-100">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-sm text-slate-400 mb-8">Supports 9 chains and growing</p>
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
      {chains.map((chain) => (
        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 border border-slate-100">
          <div class="w-6 h-6 flex items-center justify-center">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" set:html={chain.icon} />
          </div>
          <span class="text-sm font-medium text-slate-700">{chain.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
