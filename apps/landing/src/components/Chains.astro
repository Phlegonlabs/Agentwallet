  {
    name: "Fantom",
    icon: '<circle cx="12" cy="12" r="10" fill="#1969FF"/><path d="M13 6.5l2.5 1.5c.3.2.5.5.5.8v1.8L13 12.8v3.4l-1 .6-1-.6v-3.4L8 11.1V9.3c0-.3.2-.6.5-.8L11 6.5c.3-.2.7-.2 1 0zM8.5 14.5l2 1.1v2.5l-2.5-1.4c-.3-.2-.5-.5-.5-.8v-1.4zm7 0l-2 1.1v2.5l2.5-1.4c.3-.2.5-.5.5-.8v-1.4z" fill="white"/>',
