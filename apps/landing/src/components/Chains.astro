  },
  {
    name: "Optimism",
    icon: '<circle cx="12" cy="12" r="10" fill="#FF0420"/><text x="12" y="15.5" text-anchor="middle" fill="white" font-size="9" font-weight="700" font-family="sans-serif">OP</text>',
