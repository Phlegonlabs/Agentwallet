---
const chains = [
  { name: "Ethereum", icon: "/chains/ethereum.svg" },
  { name: "XLayer", icon: "/chains/xlayer.svg" },
  { name: "BSC", icon: "/chains/bnb.svg" },
  { name: "Solana", icon: "/chains/solana.svg" },
  { name: "Base", icon: "/chains/base.svg" },
  { name: "Arbitrum", icon: "/chains/arbitrum.svg" },
  { name: "Polygon", icon: "/chains/polygon.svg" },
  { name: "Optimism", icon: "/chains/optimism.svg" },
  { name: "Avalanche", icon: "/chains/avalanche.svg" },
  { name: "Fantom", icon: "/chains/fantom.svg" },
  { name: "TON", icon: "/chains/ton.svg" },
  { name: "Scroll", icon: "/chains/scroll.svg" },
];
---

<section class="py-16 px-6 border-t border-slate-100">
  <div class="max-w-5xl mx-auto">
    <p class="text-center text-sm text-slate-400 mb-8">Supports 12 chains and growing</p>
    <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-6">
      {chains.map((chain) => (
        <div class="flex items-center gap-2 px-4 py-2 rounded-lg bg-slate-50 border border-slate-100">
          <div class="w-6 h-6 flex items-center justify-center">
            <img src={chain.icon} alt={chain.name} width="20" height="20" class="w-5 h-5" />
          </div>
          <span class="text-sm font-medium text-slate-700">{chain.name}</span>
        </div>
      ))}
    </div>
  </div>
</section>
