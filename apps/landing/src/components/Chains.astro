  {
    name: "Polygon",
    icon: '<path d="M16.8 9.2c-.3-.2-.7-.2-1 0l-2.3 1.4-1.5.9-2.3 1.4c-.3.2-.7.2-1 0l-1.8-1c-.3-.2-.5-.5-.5-.9V9c0-.4.2-.7.5-.9l1.8-1c.3-.2.7-.2 1 0l1.8 1c.3.2.5.5.5.9v1.4l1.5-.9V8c0-.4-.2-.7-.5-.9L9.3 5.2c-.3-.2-.7-.2-1 0L4.6 7.1c-.3.2-.5.5-.5.9v3.8c0 .4.2.7.5.9l3.7 2.1c.3.2.7.2 1 0l2.3-1.3 1.5-.9 2.3-1.3c.3-.2.7-.2 1 0l1.8 1c.3.2.5.5.5.9v2c0 .4-.2.7-.5.9l-1.7 1c-.3.2-.7.2-1 0l-1.8-1c-.3-.2-.5-.5-.5-.9v-1.4l-1.5.9v1.4c0 .4.2.7.5.9l3.7 2.1c.3.2.7.2 1 0l3.7-2.1c.3-.2.5-.5.5-.9v-3.8c0-.4-.2-.7-.5-.9l-3.8-2.1z" fill="#8247E5"/>',
