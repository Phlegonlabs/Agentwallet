---
const severities = [
  {
    level: "info",
    color: "bg-blue-50 text-blue-700",
    dot: "bg-blue-400",
    desc: "Balance checks, wallet listings, session unlocks",
  },
  {
    level: "warn",
    color: "bg-amber-50 text-amber-700",
    dot: "bg-amber-400",
    desc: "Transfers, transaction signing, x402 payments",
  },
  {
    level: "critical",
    color: "bg-red-50 text-red-700",
    dot: "bg-red-400",
    desc: "Key exports, wallet deletions, backup restores",
  },
];
---

<section id="audit" class="py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-bold text-center text-slate-900 mb-3">Operation Audit Log</h2>
    <p class="text-center text-slate-500 mb-14 max-w-xl mx-auto">Every wallet operation is recorded with timestamps and severity levels. Your agent can query the log and alert you when it matters.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Left: Severity levels + features -->
      <div class="space-y-6">
        <!-- Severity levels -->
        <div class="bg-white rounded-xl p-6 border border-slate-100">
          <h3 class="font-semibold text-slate-900 mb-4">Three severity levels</h3>
          <div class="space-y-3">
            {severities.map((s) => (
              <div class={`flex items-start gap-3 p-3 rounded-lg ${s.color}`}>
                <div class={`flex-shrink-0 w-2.5 h-2.5 rounded-full mt-1 ${s.dot}`} />
                <div>
                  <p class="text-sm font-semibold">{s.level}</p>
                  <p class="text-xs opacity-75 mt-0.5">{s.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Key features -->
        <div class="bg-white rounded-xl p-6 border border-slate-100">
          <h3 class="font-semibold text-slate-900 mb-3">Built-in capabilities</h3>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-500 flex-shrink-0"><path d="M20 6L9 17l-5-5" /></svg>
              All operations logged automatically
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-500 flex-shrink-0"><path d="M20 6L9 17l-5-5" /></svg>
              Filter by severity and time range
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-500 flex-shrink-0"><path d="M20 6L9 17l-5-5" /></svg>
              JSON output for agent integration
            </li>
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="text-emerald-500 flex-shrink-0"><path d="M20 6L9 17l-5-5" /></svg>
              Auto-prune old entries (&gt;90 days)
            </li>
          </ul>
        </div>
      </div>

      <!-- Right: Terminal example -->
      <div>
        <div class="bg-slate-950 rounded-2xl overflow-hidden shadow-2xl shadow-slate-900/10 sticky top-8">
          <div class="flex items-center gap-2 px-4 py-3 bg-slate-900/50 border-b border-slate-800">
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <div class="w-3 h-3 rounded-full bg-slate-700"></div>
            <span class="ml-2 text-xs text-slate-500 font-mono">audit-log</span>
          </div>
          <div class="p-6 font-mono text-sm leading-relaxed space-y-6">
            <!-- Query command -->
            <div>
              <div class="flex items-center gap-2 text-slate-400">
                <span class="text-emerald-400">$</span>
                <span class="text-white">agentwallet audit-log --days 1 --json</span>
              </div>
            </div>

            <!-- JSON output -->
            <div class="text-slate-400">
              <span class="text-slate-500">{"{"}</span>
              <div class="pl-4">
                <p><span class="text-emerald-400">"total"</span>: <span class="text-amber-300">3</span>,</p>
                <p><span class="text-emerald-400">"period"</span>: <span class="text-amber-300">"last 1 day(s)"</span>,</p>
                <p><span class="text-emerald-400">"entries"</span>: [</p>
                <div class="pl-4">
                  <p>{"{"}</p>
                  <div class="pl-4">
                    <p><span class="text-emerald-400">"timestamp"</span>: <span class="text-amber-300">"2026-03-15T10:23:01Z"</span>,</p>
                    <p><span class="text-emerald-400">"event"</span>: <span class="text-amber-300">"wallet.transfer"</span>,</p>
                    <p><span class="text-emerald-400">"severity"</span>: <span class="text-amber-300">"warn"</span>,</p>
                    <p><span class="text-emerald-400">"status"</span>: <span class="text-amber-300">"success"</span>,</p>
                    <p><span class="text-emerald-400">"data"</span>: {"{"}</p>
                    <div class="pl-4">
                      <p><span class="text-emerald-400">"chain"</span>: <span class="text-amber-300">"ethereum"</span>,</p>
                      <p><span class="text-emerald-400">"amount"</span>: <span class="text-amber-300">"0.1"</span></p>
                    </div>
                    <p>{"}"}</p>
                  </div>
                  <p>{"}"},</p>
                  <p class="text-slate-600">...</p>
                </div>
                <p>]</p>
              </div>
              <span class="text-slate-500">{"}"}</span>
            </div>

            <!-- Filter by severity -->
            <div>
              <p class="text-slate-500 text-xs mb-2"># View only critical events</p>
              <div class="flex items-center gap-2 text-slate-400">
                <span class="text-emerald-400">$</span>
                <span class="text-white">agentwallet audit-log --severity critical --json</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
