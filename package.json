{
  "name": "agentwallet",
  "version": "0.1.0",
  "description": "Multi-chain crypto wallet CLI — create, encrypt, and manage wallets securely on VPS or local machines",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "agentwallet": "./dist/app/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run src/app/cli.ts",
    "build": "bun build src/app/cli.ts --outdir dist/app --target node",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format:check": "bunx biome check --no-errors-on-unmatched src/",
    "harness:advance": "bun .harness/advance.ts",
    "harness:validate": "bun .harness/validate.ts",
    "harness:guardian": "bun .harness/validate.ts --guardian",
    "harness:compact": "bun .harness/compact.ts",
    "harness:compact:milestone": "bun .harness/compact.ts --milestone",
    "harness:compact:status": "bun .harness/compact.ts --status",
    "harness:state": "bun .harness/state.ts",
    "harness:hooks:install": "bun .harness/runtime/hooks/install-git-hooks.ts",
    "harness:add-surface": "bun .harness/add-surface.ts",
    "harness:audit": "bun .harness/audit.ts",
    "harness:sync-docs": "bun .harness/sync-docs.ts",
    "harness:sync-skills": "bun .harness/sync-skills.ts",
    "harness:api:add": "bun .harness/api-add.ts",
    "harness:autoflow": "bun .harness/orchestrator.ts --auto"
  },
  "keywords": [
    "crypto",
    "wallet",
    "cli",
    "ethereum",
    "solana",
    "evm",
    "multi-chain",
    "private-key",
    "encryption",
    "vps"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/libsodium-wrappers-sumo": "^0.8.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "@solana/web3.js": "^1.98.4",
    "commander": "^14.0.3",
    "ed25519-hd-key": "^1.3.0",
    "libsodium-wrappers-sumo": "^0.8.2",
    "viem": "^2.47.4"
  }
}
